  m_Script: {fileID: 11500000, guid: 90b1af8943794c7f870ab17e35297c59, type: 3}
  m_Name: Q1_CompleteDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 0e142f5eb8d6e4de2a96b07cb34a2911, type: 3}
    speakerOnRight: 0
    text: "It worked..."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: 8bc7b80290a84470b8ede312550d16b6, type: 3}
    speakerOnRight: 1
    text: "See? It didn't need anything extraordinary. Just a little warmth."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 0e142f5eb8d6e4de2a96b07cb34a2911, type: 3}
    speakerOnRight: 0
    text: "So... is this how I can bring my garden back to life?"
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: 8bc7b80290a84470b8ede312550d16b6, type: 3}
    speakerOnRight: 1
    text: "Not all at once. But this is how it begins. Step by step."
