MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90b1af8943794c7f870ab17e35297c59, type: 3}
  m_Name: Q1_IntroPart1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: 8bc7b80290a84470b8ede312550d16b6, type: 3}
    speakerOnRight: 1
    text: "Can you feel it?"
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 0e142f5eb8d6e4de2a96b07cb34a2911, type: 3}
    speakerOnRight: 0
    text: "Feel what?"
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: 8bc7b80290a84470b8ede312550d16b6, type: 3}
    speakerOnRight: 1
    text: "How cold it is here."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 0e142f5eb8d6e4de2a96b07cb34a2911, type: 3}
    speakerOnRight: 0
    text: "But the sun is shining..."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: 8bc7b80290a84470b8ede312550d16b6, type: 3}
    speakerOnRight: 1
    text: "Sometimes light alone isn't enough."
