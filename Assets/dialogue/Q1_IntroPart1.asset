MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90b1af8943794c7f870ab17e35297c59, type: 3}
  m_Name: Q1_IntroPart1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "Can you feel it?"
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "The cold. Yeah. I thought it was just me."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "It's not just you. It's this whole place."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "But the sun is shining..."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "Sometimes light alone isn't enough."
