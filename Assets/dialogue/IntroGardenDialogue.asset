%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90b1af8943794c7f870ab17e35297c59, type: 3}
  m_Name: IntroGardenDialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "You're here. I was starting to think you'd never come back."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "Back? I've never been here before."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "You have. A long time ago. This is your garden."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "Mine? But it's all... broken."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "Nobody took care of it when it needed care most. That wasn't your fault. But you're the only one who can bring it back now."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "I don't know how to fix anything."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "Nobody does, at first. See that little tree? It's still alive. That's enough to start."
    choiceA: "And if I fail?"
    choiceB: "It's just one small tree."
    choiceKeyA: intro_fail
    choiceKeyB: intro_smalltree
    reactionA: "Then we'll try again. Gardens are patient."
    reactionB: "Every garden begins with a single tree. Don't underestimate it."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "...Okay. Show me."
