%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90b1af8943794c7f870ab17e35297c59, type: 3}
  m_Name: Q2_IntroPart2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "This one looks even weaker than the last."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "It's been thirsty for a very long time."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "Then why doesn't it rain?"
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "Because these clouds are still holding on."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "Holding on to what?"
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "To tears that were never allowed to fall."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "..."
  - speakerName: Hero
    speakerPortrait: {fileID: 21300000, guid: 328299f545de847ceacf5a3f77c61e3b, type: 3}
    speakerOnRight: 0
    text: "Can tears really help something grow?"
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "Sometimes... The tears we hide become storms inside us. The tears we let fall become rain."
  - speakerName: Bird
    speakerPortrait: {fileID: 21300000, guid: dae8213c183b84096839dba6e2624a24, type: 3}
    speakerOnRight: 1
    text: "Will you help this little plant?"
